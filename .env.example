# Sablon za produkcione tajne. Kopiraj u .env i izmeni vrednosti:
#   copy .env.example .env        (Windows)
#   cp .env.example .env          (Linux/Mac)
#
# Docker Compose automatski cita .env iz ovog foldera za ${VAR} substituciju
# u docker-compose.prod.yml. Fajl .env se NE komituje u git (vidi .gitignore).

MYSQL_ROOT_PASSWORD=changeme-root
MYSQL_PASSWORD=changeme-app
